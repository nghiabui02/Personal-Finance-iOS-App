// Secrets.xcconfig.example — Committed to git. Copy to Secrets.xcconfig and fill in real values.
// Run `xcodegen generate` after creating Secrets.xcconfig.
// NOTE: xcconfig treats // as a comment, so store only the HOST (no https://)
SUPABASE_HOST = your-project-ref.supabase.co
SUPABASE_ANON_KEY = your-supabase-anon-key-here
SUPABASE_AVATAR_BUCKET = Avatar
